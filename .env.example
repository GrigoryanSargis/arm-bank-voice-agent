# ─────────────────────────────────────────────────────────────────────────────
# Armenian Bank Voice Agent — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── LiveKit ───────────────────────────────────────────────────────────────────
# Get from livekit.io (free cloud) or run locally via docker/docker-compose.yml
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Groq API (FREE tier) ──────────────────────────────────────────────────────
# Sign up at https://console.groq.com — no credit card required.
# Free tier: Whisper STT (7200 req/day) + Llama LLM (14400 RPD)
GROQ_API_KEY=gsk_...

# ── ElevenLabs TTS (FREE tier) ────────────────────────────────────────────────
# Sign up at https://elevenlabs.io — no credit card required.
# Free tier: 10,000 characters/month
ELEVEN_API_KEY=sk_...

# ── Model overrides (defaults work fine) ─────────────────────────────────────
GROQ_STT_MODEL=whisper-large-v3
GROQ_STT_LANGUAGE=hy
GROQ_LLM_MODEL=llama-3.1-8b-instant
GROQ_LLM_TEMPERATURE=0.1

# ── Knowledge base ────────────────────────────────────────────────────────────
BANK_CHUNKS_PATH=data/processed/bank_chunks.json
KB_MAX_CHARS=20000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
